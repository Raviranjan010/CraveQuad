{
  "name": "campus-crave-monorepo",
  "version": "1.0.0",
  "description": "CampusCrave - Multi-vendor Campus Food Delivery Platform",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:web": "pnpm --filter @campus-crave/web dev",
    "dev:api": "pnpm --filter @campus-crave/api start:dev",
    "build": "pnpm -r build",
    "lint": "eslint \"**/*.{ts,tsx,js,jsx}\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:migrate": "pnpm --filter @campus-crave/api db:migrate",
    "db:generate": "pnpm --filter @campus-crave/api db:generate",
    "db:studio": "pnpm --filter @campus-crave/api db:studio"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.3",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  }
}
